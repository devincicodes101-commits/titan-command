generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────
// Multi-tenant core
// ──────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  trade     Trade    @default(HVAC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  goals          TenantGoals?
  crmCredentials CrmCredentials?
  businessUnits  BusinessUnit[]
  dailySnapshots DailySnapshot[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Trade {
  HVAC
  PLUMBING
  ELECTRICAL
  SOLAR
  GARAGE_DOORS
  ROOFING
  POOLS
  LANDSCAPE
  OTHER
}

// ──────────────────────────────────────────────────────────────
// Goals — set once, used every day
// ──────────────────────────────────────────────────────────────

model TenantGoals {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  monthlyRevenueGoal  Float    @default(0)
  monthlySoldHourGoal Float    @default(0)
  weeklyRevenueGoal   Float    @default(0)
  weeklySoldHourGoal  Float    @default(0)
  workingDaysMonth    Int      @default(20)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────
// CRM credentials — stored as AES-encrypted JSON blob
// ──────────────────────────────────────────────────────────────

enum CrmProvider {
  SERVICETITAN
  JOBBER
  MANUAL
}

model CrmCredentials {
  id            String      @id @default(cuid())
  tenantId      String      @unique
  provider      CrmProvider @default(MANUAL)
  encryptedData String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────
// Business units — configurable per tenant
// ──────────────────────────────────────────────────────────────

model BusinessUnit {
  id              String   @id @default(cuid())
  tenantId        String
  sortOrder       Int      @default(0)
  name            String
  targetCloseRate Float    @default(50)
  targetRpl       Float    @default(1000)
  includesInstall Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sortOrder])
  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Daily snapshots — saves board state per day per tenant
// ──────────────────────────────────────────────────────────────

model DailySnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime @db.Date
  inputData Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
}